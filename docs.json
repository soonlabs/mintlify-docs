{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "NebulaClaw",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#6D28D9"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://nebulaclaw.ai"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "dark"
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "navbar": {
          "links": [
            {
              "label": "Console",
              "href": "https://nonprod.nebulaclaw.ai"
            }
          ],
          "primary": {
            "type": "button",
            "label": "Get Started",
            "href": "https://nonprod.nebulaclaw.ai/login"
          }
        },
        "footer": {
          "socials": {
            "x": "https://x.com/nebulaclaw",
            "github": "https://github.com/Manta-Network/Nebulaclaw",
            "telegram": "https://t.me/nebulaclaw"
          }
        },
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart", "concepts"]
          },
          {
            "group": "Agent Setup",
            "pages": ["agent/create-agent", "agent/personality", "agent/knowledge-base"]
          },
          {
            "group": "Channels",
            "pages": ["channels/telegram", "channels/discord", "channels/slack"]
          },
          {
            "group": "Moderation",
            "pages": ["moderation/rules", "moderation/groups", "moderation/audit-log"]
          },
          {
            "group": "Analytics & Billing",
            "pages": ["analytics/dashboard", "billing/plans", "billing/usage"]
          }
        ]
      },
      {
        "language": "zh",
        "navbar": {
          "links": [
            {
              "label": "控制台",
              "href": "https://nonprod.nebulaclaw.ai"
            }
          ],
          "primary": {
            "type": "button",
            "label": "开始使用",
            "href": "https://nonprod.nebulaclaw.ai/login"
          }
        },
        "footer": {
          "socials": {
            "x": "https://x.com/nebulaclaw",
            "github": "https://github.com/Manta-Network/Nebulaclaw",
            "telegram": "https://t.me/nebulaclaw"
          }
        },
        "groups": [
          {
            "group": "快速入门",
            "pages": ["zh/introduction", "zh/quickstart", "zh/concepts"]
          },
          {
            "group": "Agent 配置",
            "pages": ["zh/agent/create-agent", "zh/agent/personality", "zh/agent/knowledge-base"]
          },
          {
            "group": "渠道集成",
            "pages": ["zh/channels/telegram", "zh/channels/discord", "zh/channels/slack"]
          },
          {
            "group": "审核管理",
            "pages": ["zh/moderation/rules", "zh/moderation/groups", "zh/moderation/audit-log"]
          },
          {
            "group": "数据分析 & 计费",
            "pages": ["zh/analytics/dashboard", "zh/billing/plans", "zh/billing/usage"]
          }
        ]
      }
    ],
    "tabs": [
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/overview", "api-reference/authentication"]
          },
          {
            "group": "Auth",
            "pages": [
              "api-reference/auth/google-login",
              "api-reference/auth/user-info",
              "api-reference/auth/logout"
            ]
          },
          {
            "group": "Gateway",
            "pages": [
              "api-reference/gateway/list-gateways",
              "api-reference/gateway/create-gateway",
              "api-reference/gateway/get-gateway",
              "api-reference/gateway/update-gateway",
              "api-reference/gateway/delete-gateway"
            ]
          },
          {
            "group": "Moderation",
            "pages": [
              "api-reference/moderation/list-rules",
              "api-reference/moderation/create-rule",
              "api-reference/moderation/update-rule",
              "api-reference/moderation/delete-rule",
              "api-reference/moderation/list-groups",
              "api-reference/moderation/add-group",
              "api-reference/moderation/update-group",
              "api-reference/moderation/delete-group"
            ]
          },
          {
            "group": "Knowledge",
            "pages": [
              "api-reference/knowledge/list-documents",
              "api-reference/knowledge/create-document",
              "api-reference/knowledge/update-document",
              "api-reference/knowledge/delete-document"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/Manta-Network/Nebulaclaw",
          "icon": "github"
        },
        {
          "anchor": "Community",
          "href": "https://t.me/nebulaclaw",
          "icon": "message-circle"
        }
      ]
    }
  }
}
